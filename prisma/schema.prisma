generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  passwordHash     String          @map("password_hash")
  referralCode     String          @unique @map("referral_code")
  points           Int             @default(0)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")
  role             UserRole        @default(CUSTOMER)
  coupons          Coupon[]
  organizedEvents  Event[]         @relation("OrganizerEvents")
  passwordResets   PasswordReset[]
  pointsHistory    PointsHistory[]
  profile          Profile?
  receivedReferral ReferralUsage?  @relation("ReferredUserUsage")
  sentReferrals    ReferralUsage[] @relation("ReferrerUsage")
  refreshTokens    RefreshToken[]
  reviews          Review[]
  transactions     Transaction[]

  @@map("users")
}

model Profile {
  userId    String   @id @map("user_id")
  fullName  String?  @map("fullname")
  phone     String?
  photoUrl  String?  @map("photo_url")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model PointsHistory {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  amount          Int
  expiresAt       DateTime?   @map("expires_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  referenceId     String?     @map("reference_id")
  referenceType   String?     @map("reference_type")
  remainingAmount Int?        @map("remaining_amount")
  type            PointType
  source          PointSource
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("points_history")
}

model ReferralUsage {
  id             String   @id @default(uuid())
  referrerId     String   @map("referrer_id")
  referredUserId String   @unique @map("new_user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  couponId       String?  @unique @map("coupon_id")
  coupon         Coupon?  @relation(fields: [couponId], references: [id])
  referredUser   User     @relation("ReferredUserUsage", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrer       User     @relation("ReferrerUsage", fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("referral_usages")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  usedAt    DateTime? @map("used_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Event {
  id           String        @id @default(uuid())
  organizerId  String        @map("organizer_id")
  name         String
  description  String?
  category     String
  location     String
  startDate    DateTime      @map("start_date")
  endDate      DateTime      @map("end_date")
  deletedAt    DateTime?     @map("deleted_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  bannerUrl    String?       @map("banner_url")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  status       EventStatus   @default(DRAFT)
  organizer    User          @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: Cascade)
  reviews      Review[]
  ticketTypes  TicketType[]
  transactions Transaction[]
  vouchers     Voucher[]

  @@index([organizerId])
  @@index([category])
  @@index([location])
  @@index([startDate])
  @@map("events")
}

model TicketType {
  id             String            @id @default(uuid())
  eventId        String            @map("event_id")
  name           String
  price          Int
  quota          Int
  createdAt      DateTime          @default(now()) @map("created_at")
  availableQuota Int               @map("available_quota")
  updatedAt      DateTime          @default(now()) @updatedAt @map("updated_at")
  event          Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items          TransactionItem[]

  @@index([eventId])
  @@map("ticket_types")
}

model Transaction {
  id                     String            @id @default(uuid())
  userId                 String            @map("user_id")
  eventId                String            @map("event_id")
  totalAmount            Int               @map("total_amount")
  pointsUsed             Int               @default(0) @map("points_used")
  finalAmount            Int               @map("final_amount")
  paymentProofUrl        String?           @map("payment_proof")
  createdAt              DateTime          @default(now()) @map("created_at")
  confirmationDeadlineAt DateTime?         @map("confirmation_deadline_at")
  couponDiscount         Int               @default(0) @map("coupon_discount")
  couponId               String?           @map("coupon_id")
  paymentDeadlineAt      DateTime          @map("payment_deadline_at")
  paymentUploadedAt      DateTime?         @map("payment_uploaded_at")
  rejectionReason        String?           @map("rejection_reason")
  updatedAt              DateTime          @default(now()) @updatedAt @map("updated_at")
  voucherDiscount        Int               @default(0) @map("voucher_discount")
  voucherId              String?           @map("voucher_id")
  status                 TransactionStatus @default(WAITING_PAYMENT)
  items                  TransactionItem[]
  coupon                 Coupon?           @relation(fields: [couponId], references: [id])
  event                  Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucher                Voucher?          @relation(fields: [voucherId], references: [id])

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@map("transactions")
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String      @map("transaction_id")
  ticketTypeId  String      @map("ticket_type_id")
  quantity      Int
  subtotal      Int
  createdAt     DateTime    @default(now()) @map("created_at")
  price         Int
  ticketType    TicketType  @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId, ticketTypeId])
  @@map("transaction_items")
}

model Voucher {
  id             String        @id @default(uuid())
  eventId        String        @map("event_id")
  code           String        @unique
  discountAmount Int           @map("discount_value")
  startDate      DateTime      @map("start_date")
  endDate        DateTime      @map("end_date")
  createdAt      DateTime      @default(now()) @map("created_at")
  quota          Int?
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")
  usedCount      Int           @default(0) @map("used_count")
  transactions   Transaction[]
  event          Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("vouchers")
}

model Coupon {
  id             String         @id @default(uuid())
  code           String         @unique
  discountAmount Int            @map("discount")
  validUntil     DateTime       @map("valid_until")
  isUsed         Boolean        @default(false) @map("is_used")
  userId         String         @map("user_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  source         CouponSource   @default(REFERRAL)
  usedAt         DateTime?      @map("used_at")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  referralUsage  ReferralUsage?
  transactions   Transaction[]

  @@index([userId, isUsed])
  @@map("coupons")
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("reviews")
}

enum UserRole {
  CUSTOMER
  ORGANIZER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  FINISHED
  CANCELED
}

enum TransactionStatus {
  WAITING_PAYMENT
  WAITING_CONFIRMATION
  DONE
  REJECTED
  EXPIRED
  CANCELED
}

enum CouponSource {
  REFERRAL
}

enum PointType {
  CREDIT
  DEBIT
}

enum PointSource {
  REFERRAL_REWARD
  TRANSACTION_USE
  TRANSACTION_REFUND
  EXPIRED
}
